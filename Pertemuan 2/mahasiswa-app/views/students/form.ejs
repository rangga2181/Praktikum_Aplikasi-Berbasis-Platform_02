<%- include('../layout', { body: `
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h4 class="mb-0">
                    <i class="fas fa-${isEdit ? 'edit' : 'plus'}-circle me-2 text-primary"></i>
                    ${title}
                </h4>
            </div>
            <div class="card-body">
                <form id="studentForm" method="POST" action="${isEdit ? '/api/students/' + student.id : '/api/students'}" data-edit="${isEdit}" data-id="${student ? student.id : ''}">
                    <div class="mb-3">
                        <label for="nim" class="form-label">NIM <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="nim" name="nim" 
                               value="${student ? student.nim : ''}" 
                               placeholder="Masukkan NIM" maxlength="10">
                        <div class="invalid-feedback"></div>
                    </div>

                    <div class="mb-3">
                        <label for="nama" class="form-label">Nama Lengkap <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="nama" name="nama" 
                               value="${student ? student.nama : ''}" 
                               placeholder="Masukkan nama lengkap" maxlength="100">
                        <div class="invalid-feedback"></div>
                    </div>

                    <div class="mb-3">
                        <label for="prodi" class="form-label">Program Studi <span class="text-danger">*</span></label>
                        <select class="form-select" id="prodi" name="prodi">
                            <option value="">Pilih Program Studi</option>
                            <option value="Teknik Informatika" ${student && student.prodi === 'Teknik Informatika' ? 'selected' : ''}>Teknik Informatika</option>
                            <option value="Sistem Informasi" ${student && student.prodi === 'Sistem Informasi' ? 'selected' : ''}>Sistem Informasi</option>
                            <option value="Manajemen Informatika" ${student && student.prodi === 'Manajemen Informatika' ? 'selected' : ''}>Manajemen Informatika</option>
                            <option value="Teknik Elektro" ${student && student.prodi === 'Teknik Elektro' ? 'selected' : ''}>Teknik Elektro</option>
                            <option value="Teknik Telekomunikasi" ${student && student.prodi === 'Teknik Telekomunikasi' ? 'selected' : ''}>Teknik Telekomunikasi</option>
                        </select>
                        <div class="invalid-feedback"></div>
                    </div>

                    <div class="mb-3">
                        <label for="angkatan" class="form-label">Angkatan <span class="text-danger">*</span></label>
                        <select class="form-select" id="angkatan" name="angkatan">
                            <option value="">Pilih Angkatan</option>
                            <option value="2024" ${student && student.angkatan === '2024' ? 'selected' : ''}>2024</option>
                            <option value="2023" ${student && student.angkatan === '2023' ? 'selected' : ''}>2023</option>
                            <option value="2022" ${student && student.angkatan === '2022' ? 'selected' : ''}>2022</option>
                            <option value="2021" ${student && student.angkatan === '2021' ? 'selected' : ''}>2021</option>
                            <option value="2020" ${student && student.angkatan === '2020' ? 'selected' : ''}>2020</option>
                        </select>
                        <div class="invalid-feedback"></div>
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">Email <span class="text-danger">*</span></label>
                        <input type="email" class="form-control" id="email" name="email" 
                               value="${student ? student.email : ''}" 
                               placeholder="contoh: nama@student.telkom.ac.id" maxlength="100">
                        <div class="invalid-feedback"></div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a href="/students" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Batal
                        </a>
                        <button type="reset" class="btn btn-warning">
                            <i class="fas fa-undo me-1"></i> Reset
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i> ${isEdit ? 'Update' : 'Simpan'}
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
`, title: title, active: 'input', scripts: '<script src="/js/form-validation.js"></script>' }) %>
